# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/sentiment
DATABASE_URL_SYNC=postgresql://postgres:postgres@postgres:5432/sentiment

# Redis / arq
REDIS_URL=redis://redis:6379/0

# Embedding model
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
EMBEDDING_BATCH_SIZE=32

# Chunking
CHUNK_MAX_TOKENS=400
CHUNK_OVERLAP_TOKENS=50
SEMANTIC_BREAKPOINT_PERCENTILE=85

# Clustering — UMAP
UMAP_N_NEIGHBORS=20
UMAP_MIN_DIST=0.05
UMAP_N_COMPONENTS=5
UMAP_METRIC=cosine

# Clustering — HDBSCAN
HDBSCAN_MIN_CLUSTER_SIZE=25
HDBSCAN_MIN_SAMPLES=10
HDBSCAN_CLUSTER_SELECTION=eom

# Topic lifecycle thresholds
KNN_ASSIGN_THRESHOLD=0.75
CENTROID_MATCH_THRESHOLD=0.85

# Emergence
EMERGENCE_FRESH_MIN_COUNT=2
EMERGENCE_RATIO_THRESHOLD=2.0

# Clustering cron (24h default)
CLUSTERING_CRON_HOURS=24

# AWS Bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Bedrock requires an inference-profile ID for Sonnet 4.x (not a raw foundation model ID).
# Use the US or Global cross-region profile depending on your account's enabled regions:
#   us.anthropic.claude-sonnet-4-6
#   global.anthropic.claude-sonnet-4-6
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Toggle for tests / local dev without Bedrock access
MOCK_LLM=false

# Raw storage
RAW_STORAGE_PATH=/app/data/raw

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
